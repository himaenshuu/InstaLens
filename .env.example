# Environment Variables Template
# Copy this file to .env and replace the placeholder values with your actual keys

# Supabase Configuration
# Get these from: https://app.supabase.com/project/_/settings/api
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Apify Configuration (for Instagram scraping)
# Get your API token from: https://console.apify.com/account/integrations
VITE_APIFY_API_TOKEN=your_apify_api_token

# Google Cloud Vision API (Optional - for AI content analysis)
# Get your API key from: https://console.cloud.google.com/apis/credentials
# Without this key, the app will use caption-based analysis as fallback
# First 1,000 requests/month are FREE!
VITE_GOOGLE_VISION_API_KEY=your_google_vision_api_key

# Server Configuration
VITE_API_BASE_URL=your_supabase_project_url/functions/v1